------------------ Aufgabe 6 -------------------------------------------------------------------------
SELECT 
    l.name AS lesername,
    b.titel AS buchtitel,
    a.ausleih_datum,
    a.rueckgabe_datum
FROM ausleihe a
JOIN leser l ON a.leser_id = l.id
JOIN buch b ON a.buch_id = b.id
ORDER BY a.ausleih_datum DESC;


SELECT 
    b.titel,
    l.name AS lesername,
    a.ausleih_datum
FROM ausleihe a
JOIN leser l ON a.leser_id = l.id
JOIN buch b ON a.buch_id = b.id
WHERE a.rueckgabe_datum IS NULL;


SELECT 
    b.titel,
    COUNT(*) AS anzahl_ausleihen
FROM ausleihe a
JOIN buch b ON a.buch_id = b.id
GROUP BY b.id, b.titel;


SELECT 
    l.name,
    COUNT(*) AS anzahl_ausleihen
FROM ausleihe a
JOIN leser l ON a.leser_id = l.id
GROUP BY l.id, l.name
ORDER BY anzahl_ausleihen DESC
LIMIT 1;