------------------ Aufgabe 1 -------------------------------------------------------------------------
create table leser (id int AUTO_INCREMENT primary key, name text Not null, email text not null unique, mitglied_seit text not null);

------------------ Aufgabe 2 -------------------------------------------------------------------------
create table Buch (id int AUTO_INCREMENT primary key, titel text Not null, autor text not null, isbn text unique, erscheinungsjahr int);

------------------ Aufgabe 3 -------------------------------------------------------------------------
create table ausleihe (leser_id int not null, buch_id int not null, ausleih_datum text not null, rueckgabe_datum text, anzahl_tage int not null check (anzahl_tage > 0), 
        primary key (leser_id, buch_id, ausleih_datum),
        foreign key (leser_id) references leser(id) on delete restrict,
        foreign key (buch_id) references buch(id) on delete restrict);


------------------ Aufgabe 4 -------------------------------------------------------------------------
create index idx_Leser_Name on leser(name);
create index idx_Buch_Titel on Buch(titel);
create index idx_ausgeliehene_Buecher on ausleihe(buch_id) where rueckgabe_datum is null;

