erdiagram Model
notation=crowsfoot

entity Leser {
   id key
   name
   email
   mitglied_seit
}

entity Buch {
    id key
    titel 
    autor
    isbn
    verfuegbar
}


entity Mitarbeiter {
   titel key
   Autor
   Verlag
   ISBN 
}

entity Exemplar {
   physisches_Exemplar key 
   BuchID  key 
   Standort 
   Status 
}


relationship Ausleihr {
   Mitarbeiter [N] -> Exemplar [N] -> Leser [N] 
   id: int key
   leser_id 
   buch_id
   ausleih_datum
   rueckgabe_datum
}

relationship Buch_Exemplar {
   Buch [1] -> Exemplar [N]
}



