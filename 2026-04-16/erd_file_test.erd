erdiagram Model

entity Leser {
   id: int key
   name: text
   email:  text 
   mitglied_seit: text 
}

entity Buch {
    id: int key
    titel: text 
    autor: text
    isbn: text unique
    verfuegbar: boolean 
}

entity Ausleihr {
   id: int key
   leser_id: int 
   buch_id: int 
   ausleih_datum: text 
   rueckgabe_datum: text
}

relationship Test {
   Leser [1]-> Ausleihr [N]
}
