erdiagram Model

entity Leser {
   id: int key
   name: text
   email:  text 
   mitglied_seit: text 
}

entity Buch {
    id: int key
    titel: text 
    autor: text
    isbn: text unique
    verfuegbar: boolean 
}

entity Ausleihr {
   id: int key
   leser_id: int 
   buch_id: int 
   ausleih_datum: text 
   rueckgabe_datum: text
}
entity Mitarbeiter {
   titel: text key
   Autor: text 
   Verlag: text
   ISBN: text unique
}

relationship Leser_A {
   Leser [1]-> Ausleihr [N]
}
relationship Buch_A {
   Buch [1]-> Ausleihr [N]
}
relationship Ausleihe_M {
   Ausleihr [N] -> Mitarbeiter [1]
}


